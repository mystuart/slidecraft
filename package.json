{
  "name": "slidecraft",
  "version": "1.4.0",
  "private": true,
  "description": "Interactive Slidecraft handouts from Markdown. 24 components · single-file · zero runtime.",
  "main": "build.js",
  "scripts": {
    "build": "node build.js",
    "build:watch": "node build.js --watch",
    "build:three": "node_modules/.bin/esbuild three-bundle.js --bundle --format=iife --target=es2020 --minify --outfile=three-bundle.iife.js",
    "dev": "node build.js --watch & python3 -m http.server 8000 --directory dist",
    "test": "node --test \"test/**/*.test.js\"",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "katex": "^0.16.9",
    "marked": "^18.0.4",
    "three": "^0.184.0",
    "highlight.js": "^11.11.1"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  },
  "author": "Stuart Ma <mystuart@163.com>",
  "license": "MIT",
  "keywords": [
    "slidecraft",
    "markdown",
    "courseware",
    "education",
    "single-file",
    "interactive",
    "katex",
    "three-js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mystuart/slidecraft.git"
  },
  "homepage": "https://github.com/mystuart/slidecraft#readme",
  "bugs": {
    "url": "https://github.com/mystuart/slidecraft/issues"
  }
}