# 依赖
node_modules/

# 编译产物（dist/.gitkeep 保留，dist/*.html 忽略）
dist/*
!dist/.gitkeep

# Three.js 打包产物（build.js 现成读 node_modules/three/build 打）
# 这两个文件约 730KB，build.js 会把 bundle 内联进 dist/*.html，仓库不存档
cw-three-bundle.iife.js
cw-three-bundle.js

# 系统
.DS_Store
Thumbs.db

# 编辑器 / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 日志
*.log
npm-debug.log*

# 环境
.env
.env.local

# Alice 工具自动生成的临时文件
*.alice-buffer-*.tmp
.commit-msg.tmp

# 临时 commit message 文件（用 git commit -F 时会写）

